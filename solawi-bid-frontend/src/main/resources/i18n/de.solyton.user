de {
    solyton {
        user {
            managementPage {
                title: "Nutzer Verwaltung"
                buttons {
                    createUser {
                        title: "Nutzer erstellen"
                    }
                }
                dialogs {
                    createUser {
                        title: "Nutzer erstellen"
                        inputs {
                            username {
                                title: "Nutzername"
                            }
                            password {
                                title: "Passwort"
                            }
                            repeatPassword{
                                title: "Passwort wiederholen"
                            }
                        }
                        okButton {
                            title: "Ok"
                        }
                        cancelButton {
                            title: "Abbrechen"
                        }
                        errors {
                            wrongPassword: "Falsches Passwort"
                            requirementsViolated: "Passwortanforferungen verletzt"
                            repeatedPasswordMismatch: "Passwörter stimmen nicht überein"
                            newPasswordEqualsOld: "Das neue Passwort muss sich vom alten unterscheiden"
                        }
                    }
                }
                registeredUsers {
                    title: "Registrierte Nutzer"
                    buttons {
                        edit {
                            title: "Bearbeiten"
                        }
                        delete {
                            title: "Löschen"
                        }
                    }
                }
                permissions {
                    title: "Berechtigungen"
                    table {
                        title: "Rollen in Kontexten"
                        columns {
                            context {
                                title: "Kontext"
                            }
                            roles {
                                title: "Rollen"
                            }
                        }
                    }
                }
            }
            privatePage {
                title: "Persönliche Daten"
                buttons {
                    changePassword {
                        title: "Passwort ändern"
                    }
                }
                personalData {
                    title: "Deine Daten"
                    properties {
                        username {
                            value: "Nutzername"
                        }
                        firstname {
                            value: "Vorname"
                        }
                        lastname {
                            value: "Nachname"
                        }
                        title {
                            value: "Titel"
                        }
                        address {
                            value: "Adresse"
                        }
                    }
                }
                permissions {
                    title: "Berechtigungen"
                    table {
                        title: "Rollen in Kontexten"
                        columns {
                            context {
                                title: "Kontext"
                            }
                            roles {
                                title: "Rollen"
                            }
                            rights {
                                title: "Rechte"
                            }
                        }
                    }
                }
                dialogs {
                    changePassword {
                        title: "Passwort Ändern"
                        inputs {
                            oldPassword {
                                title: "Altes Passwort"
                            }
                            newPassword {
                                title: "Neues Passwort"
                            }
                            repeatPassword {
                                title: "Passwort wiederholen"
                            }
                        }
                        errors {
                            wrongPassword: "Falsches Passwort"
                            requirementsViolated: "Passwortanforferungen verletzt"
                            repeatedPasswordMismatch: "Passwörter stimmen nicht überein"
                            newPasswordEqualsOld: "Das neue Passwort muss sich vom alten unterscheiden"
                        }
                        okButton {
                            title: "Ok"
                        }
                        cancelButton {
                            title: "Abbrechen"
                        }

                    }
                    updateUserProfile {
                        title: "Nutzer Profil bearbeiten"
                        inputs {
                         userProfile {
                             formTitle: "Persönliche Daten"
                             username {
                                title: "Email"
                             }
                             firstname {
                                 title: "Vorname"
                             }
                             lastname {
                                 title: "Nachname"
                             }
                             title {
                                title: "Titel"
                             }
                             phoneNumber {
                                title: "Telefon"
                             }
                             cellPhoneNumber {
                                title: "Mobil"
                             }
                             address {
                                title: "Adresse"
                                recipientName {
                                    title: "Empfänger"
                                }
                                organizationName {
                                    title: "Firma / Organisation"
                                }
                                addressLine1 {
                                    title: "Straße, Hausnr."
                                }
                                addressLine2 {
                                    title: "Adress Zusatz"
                                }
                                city {
                                    title: "Stadt"
                                }
                                stateOrProvince {
                                    title: "Bundesland"
                                }
                                postalCode {
                                    title: "PLZ"
                                }
                                countryCode {
                                    title: "Land"
                                }
                             }
                         }
                        }
                        okButton {
                            title: "Ok"
                        }
                        cancelButton {
                            title: "Abbrechen"
                        }
                    }
                }
            }
        }
    }
}
