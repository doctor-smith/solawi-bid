FROM mcr.microsoft.com/playwright:v1.40.0-focal

# System-Level Performance
ENV GRADLE_OPTS="-Xmx2g -XX:+UseG1GC -XX:+UseStringDeduplication"
ENV JAVA_OPTS="-Xmx2g"

# Gradle Configuration (not dependencies!)
RUN mkdir -p /root/.gradle && \
    echo "org.gradle.caching=true" >> /root/.gradle/gradle.properties && \
    echo "org.gradle.parallel=true" >> /root/.gradle/gradle.properties && \
    echo "org.gradle.daemon=false" >> /root/.gradle/gradle.properties && \
    echo "org.gradle.configureondemand=true" >> /root/.gradle/gradle.properties

# Playwright CI optimizations
ENV PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=true
ENV CI=true

# Build arguments for labels
ARG GITHUB_REPOSITORY
ARG BUILD_DATE
ARG VERSION

# Environment variables
ENV GRADLE_VERSION=8.5
ENV GRADLE_HOME=/opt/gradle-${GRADLE_VERSION}
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
ENV PATH=${GRADLE_HOME}/bin:${PATH}

# System updates and basic dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    gnupg \
    lsb-release \
    wget \
    unzip \
    git \
    sudo \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Java 17 (if not already available in the Playwright image)
RUN apt-get update && apt-get install -y \
    openjdk-17-jdk \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Securely install Docker (official method)
RUN mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null \
    && apt-get update \
    && apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Gradle with checksum verification
RUN wget -q https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip \
    && echo "9d926787066a081739e8200858338b4a69e837c3a821a33aca9db09dd4a41026 *gradle-${GRADLE_VERSION}-bin.zip" | sha256sum -c - \
    && unzip gradle-${GRADLE_VERSION}-bin.zip -d /opt \
    && rm gradle-${GRADLE_VERSION}-bin.zip \
    && chmod +x ${GRADLE_HOME}/bin/gradle

# Create a non-root user for improved security
RUN groupadd -r testuser && useradd -r -g testuser -m -d /home/testuser -s /bin/bash testuser \
    && usermod -aG docker testuser \
    && usermod -aG sudo testuser \
    && echo 'testuser ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers

# Set working directory
WORKDIR /workspace

# Set workspace permissions for testuser
RUN chown -R testuser:testuser /workspace

# FIX: Root user for GitHub Actions services
USER root

# FIX: Health check that works (without Docker socket)
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD gradle --version && echo "Health check passed" || exit 1

# FIX: Keep alive for services
CMD ["sleep", "infinity"]

# Labels for better management
LABEL org.opencontainers.image.title="E2E Test Runner" \
      org.opencontainers.image.description="E2E Test Runner with Playwright, Docker, Java 17 and Gradle" \
      org.opencontainers.image.source="https://github.com/${GITHUB_REPOSITORY}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.vendor="Solyton" \
      org.opencontainers.image.licenses="MIT"

# Only Java, Gradle, Docker - NO dependencies!